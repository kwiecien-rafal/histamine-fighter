# Backend
DEBUG=true
# Browser origins allowed to call the API from JavaScript, and the trusted-Origin
# set for the cross-origin check on admin mutations. Admin auth rides in a
# same-origin session cookie, so the SPA and API must share an origin: in dev the
# Vite proxy fronts both on :5173; in production reverse-proxy /api and /admin under
# the SPA's host rather than a separate subdomain. To drive admin mutations from
# Swagger at :8000, add "http://localhost:8000" here (an unlisted Origin on a
# POST/PATCH/DELETE is refused with 403).
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Database connection (asyncpg driver). For native dev, localhost works.
# Inside Docker Compose, use the db service name as the host: ...@db:5432/histamine
DATABASE_URL=postgresql+asyncpg://histamine:histamine@localhost:5432/histamine

# Set true on the hosted/public deployment. Disables Ollama (which can't reach a
# visitor's localhost from a public server) and shifts the frontend default away
# from Ollama. Leave false for local dev and self-hosted setups.
PUBLIC_DEPLOYMENT=false

# Frontend mirror of PUBLIC_DEPLOYMENT — Vite only exposes vars prefixed VITE_.
# Must match PUBLIC_DEPLOYMENT for the UI to render the correct provider list.
VITE_PUBLIC_DEPLOYMENT=false

# Admin auth. SECRET_KEY signs the JWT issued at /admin/auth/login. Leave blank
# for local dev (it falls back to an insecure placeholder). Production refuses to
# start without a strong, non-default value (>=32 chars) once DEBUG=false or
# PUBLIC_DEPLOYMENT=true. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Name of the httpOnly session cookie set at /admin/auth/login. Its Secure flag is
# driven by PUBLIC_DEPLOYMENT (assumes HTTPS) and its lifetime tracks
# ACCESS_TOKEN_EXPIRE_MINUTES. Rarely needs changing.
SESSION_COOKIE_NAME=hf_session

# Hour (0-23) the daily board unlocks. Deliberately UTC, not local time, so the
# reveal is the same instant for every visitor. The generation script stamps each
# suggestion's reveal time from this.
DAILY_REVEAL_HOUR_UTC=10

# Server-side fallback LLM provider when the request carries no X-LLM-Provider header.
# One of: ollama | openai | anthropic | gemini | openrouter. The web app always sends
# the header, so this only matters for direct API calls (curl, scripts).
LLM_PROVIDER=ollama

# Ollama (used when LLM_PROVIDER=ollama or X-LLM-Provider: ollama).
# For native dev, localhost is fine. From inside Docker, use http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

# --- HuggingFace (optional) ---
# On startup the backend downloads a small embedding model from HuggingFace.
# Anonymous downloads are rate-limited; if boot fails with "Server disconnected"
# or a "set a HF_TOKEN" warning, add a free read token to lift the limit.
# Create one (read scope is enough) at https://huggingface.co/settings/tokens
# Read directly by huggingface_hub; Docker Compose forwards it to the backend.
HF_TOKEN=

# --- Bring your own key (optional) ---
# Users normally paste their key in the web app's Settings panel; it travels as a
# per-request header and is never stored. The vars below are only a server-side
# fallback for local testing or self-hosting when no X-LLM-API-Key header is sent.
# OpenAI keys:     https://platform.openai.com/api-keys
# Anthropic keys:  https://console.anthropic.com/settings/keys
# Gemini keys:     https://aistudio.google.com/apikey
# OpenRouter keys: https://openrouter.ai/keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
